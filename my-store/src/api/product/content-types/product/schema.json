{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "description": {
      "type": "string"
    },
    "price_display": {
      "type": "string",
      "maxLength": 10
    },
    "old_price": {
      "type": "string"
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "salePrice": {
      "type": "decimal"
    },
    "stock": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "sku": {
      "type": "string",
      "unique": true
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "mappedBy": "products"
    },
    "colors": {
      "type": "json"
    },
    "sizes": {
      "type": "json"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "videos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "model3D": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "textures": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "tryon_settings": {
      "type": "json"
    },
    "foot_type": {
      "type": "enumeration",
      "enum": [
        "left",
        "right",
        "both"
      ]
    },
    "slug": {
      "type": "uid",
      "targetField": ""
    },
    "contact_requests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::contact-request.contact-request",
      "mappedBy": "product"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "product"
    },
    "variants": {
      "type": "component",
      "repeatable": true,
      "component": "product.variant"
    }
  }
}
