{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "customer": {
      "type": "json",
      "required": true
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order-item.order-item",
      "mappedBy": "order"
    },
    "subtotal": {
      "type": "decimal",
      "required": true
    },
    "discount": {
      "type": "decimal",
      "default": 0
    },
    "shippingFee": {
      "type": "decimal",
      "default": 0
    },
    "total": {
      "type": "decimal",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "confirmed",
        "processing",
        "shipped",
        "delivered",
        "cancelled",
        "en_livraison"
      ],
      "default": "pending"
    },
    "paymentStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "emballage",
        "en_livraison",
        "paid",
        "failed"
      ],
      "default": "pending"
    },
    "paymentMethod": {
      "type": "string",
      "default": "cash_on_delivery"
    },
    "couponCode": {
      "type": "string"
    },
    "coupon": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::coupon.coupon"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "pointsAwarded": {
      "type": "boolean",
      "default": false
    }
  }
}
